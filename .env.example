# ProtestBase Environment Variables
# Copy this file to .env.local and fill in your values

# App environment: development | preview | production
APP_ENV=development

# API Backend
# Host only — no trailing slash, no /api path. The prefix is fetched dynamically from /app/config.
# e.g. https://api-test.protestbase.be
EXPO_PUBLIC_API_BASE_URL=<api-base-url>

# EAS Build (optional — defaults are provided in app.config.ts)
EXPO_PUBLIC_EAS_PROJECT_ID=<eas-project-id>
EXPO_PUBLIC_PROJECT_SLUG=<project-slug>
EXPO_PUBLIC_EAS_OWNER=<eas-owner>

# App Integrity / Install Token
# ------------------------------------------------------------------
# Android uses Hardware Key Attestation via the local `modules/expo-hka` Expo
# module — no Cloud project number is required (we no longer use Play
# Integrity).
#
# Required for `development` builds only. Skips native attestation and instead
# sends `X-Dev-Integrity-Bypass: <secret>` on every API request. The backend
# honors this only when its own NODE_ENV !== 'production'. `preview` and
# `production` builds run real attestation (App Attest on iOS, Hardware Key
# Attestation on Android) and MUST NOT set this value.
#
# Generate with: openssl rand -base64 32
# Match this value with the backend's DEV_INTEGRITY_BYPASS env var for the
# `development` environment.
#
# For EAS builds, set via:
#   eas env:create --environment development --name EXPO_PUBLIC_DEV_INTEGRITY_BYPASS \
#     --value '<secret>' --visibility secret
EXPO_PUBLIC_DEV_INTEGRITY_BYPASS=<dev-bypass-secret>
